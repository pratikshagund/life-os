# ============================================================
# LifeOS Backend — Required Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# ============================================================

# Server
PORT=8080

# Database (Railway auto-provides DATABASE_URL when you add PostgreSQL plugin)
DATABASE_URL=jdbc:postgresql://localhost:5433/lifeos
DATABASE_USERNAME=lifeos_user
DATABASE_PASSWORD=lifeos_password

# JWT — generate a strong 256-bit Base64 secret:
# Run: openssl rand -base64 32
JWT_SECRET_KEY=replace-with-a-strong-secret-key
JWT_EXPIRATION=86400000

# OpenAI (optional — mock is used if not set)
OPENAI_API_KEY=sk-your-openai-key-here

# CORS — set to your Vercel frontend URL after deployment
# Example: https://life-os-ui.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:4200
